rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: own read/write. Also allow updating colaborator-related fields by other auth'd users
    // (needed when owner assigns existing user as colaborador).
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['collaboratingPropertyIds', 'roles', 'updatedAt']);
    }

    // Properties: public read if isPublic, owner or colaborator read/write.
    // Tenant can read property where they are tenantUid.
    // Tenant can update tenantUid + updatedAt on first login (email match).
    match /properties/{propertyId} {
      allow read: if resource.data.isPublic == true
                  || (request.auth != null && request.auth.uid == resource.data.ownerId)
                  || (request.auth != null && request.auth.uid in resource.data.get('collaboratorUids', []))
                  || (request.auth != null && request.auth.uid == resource.data.tenantUid);
      allow create: if request.auth != null && request.auth.uid == request.resource.data.ownerId;
      allow update, delete: if request.auth != null && (
        request.auth.uid == resource.data.ownerId
        || request.auth.uid in resource.data.get('collaboratorUids', [])
      );
      // Allow tenant to link their uid on first login (only tenantUid + updatedAt fields)
      allow update: if request.auth != null
                    && request.auth.token.email == resource.data.tenantEmail
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['tenantUid', 'updatedAt']);
    }

    // Payments: owner or colaborador can read/write; tenant can read payments for their property.
    match /payments/{paymentId} {
      function isCollaboratorOnPayment() {
        return request.auth != null
               && request.auth.uid in get(/databases/$(database)/documents/properties/$(resource.data.propertyId))
                                      .data.get('collaboratorUids', []);
      }

      allow read: if request.auth != null && (
        request.auth.uid == resource.data.ownerId
        || isCollaboratorOnPayment()
        || request.auth.uid == get(/databases/$(database)/documents/properties/$(resource.data.propertyId)).data.tenantUid
      );
      allow write: if request.auth != null && (
        request.auth.uid == resource.data.ownerId
        || isCollaboratorOnPayment()
      );
      allow create: if request.auth != null && (
        request.auth.uid == request.resource.data.ownerId
        || request.auth.uid in get(/databases/$(database)/documents/properties/$(request.resource.data.propertyId))
                               .data.get('collaboratorUids', [])
      );
    }

    // Expenses: only the owner can read/write
    match /expenses/{expenseId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == resource.data.ownerId;
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.ownerId;
    }

    // Tickets: owner or colaborador can read/update; tenant can read/create their own.
    match /tickets/{ticketId} {
      function isCollaboratorOnTicket() {
        return request.auth != null
               && request.auth.uid in get(/databases/$(database)/documents/properties/$(resource.data.propertyId))
                                      .data.get('collaboratorUids', []);
      }

      allow read: if request.auth != null && (
        request.auth.uid == resource.data.ownerId
        || request.auth.uid == resource.data.tenantUid
        || isCollaboratorOnTicket()
      );
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.tenantUid;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.ownerId
        || isCollaboratorOnTicket()
      );
      allow delete: if false;
    }

    // Notifications: owner reads their own; written only by Cloud Functions (Admin SDK).
    match /notifications/{notifId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.ownerId;
      allow write: if false; // Cloud Functions (Admin SDK) only
    }

    // PaymentLinks: owner reads/creates; tenant reads links for their property.
    match /paymentLinks/{linkId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.ownerId
        || request.auth.uid == get(/databases/$(database)/documents/properties/$(resource.data.propertyId)).data.tenantUid
      );
      allow create: if request.auth != null && request.auth.uid == request.resource.data.ownerId;
      allow update: if false; // Cloud Functions (Admin SDK) only
      allow delete: if false;
    }

    // MonthlySnapshots: owner reads their own; written only by Cloud Functions.
    match /monthlySnapshots/{snapshotId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.ownerId;
      allow write: if false; // Cloud Functions (Admin SDK) only
    }

    // Mail: write-only from Cloud Functions (Admin SDK). No client access needed.
    match /mail/{mailId} {
      allow read, write: if false;
    }
  }
}
