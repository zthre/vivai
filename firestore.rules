rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Properties: public read if isPublic == true, owner read/write otherwise
    match /properties/{propertyId} {
      allow read: if resource.data.isPublic == true || (request.auth != null && request.auth.uid == resource.data.ownerId);
      allow write: if request.auth != null && request.auth.uid == resource.data.ownerId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.ownerId;
    }

    // Units: public read if parent property isPublic == true, owner read/write otherwise
    match /units/{unitId} {
      allow read: if get(/databases/$(database)/documents/properties/$(resource.data.propertyId)).data.isPublic == true
                  || (request.auth != null && request.auth.uid == resource.data.ownerId);
      allow write: if request.auth != null && request.auth.uid == resource.data.ownerId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.ownerId;
    }

    // Payments: only the owner can read/write
    match /payments/{paymentId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == resource.data.ownerId;
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.ownerId;
    }

    // Expenses: only the owner can read/write
    match /expenses/{expenseId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == resource.data.ownerId;
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.ownerId;
    }
  }
}
